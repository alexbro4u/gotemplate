# Application
LOG_LEVEL=info
APP_ENV=dev

# HTTP Server
HTTP_HOST=localhost
HTTP_PORT=8080
HTTP_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
HTTP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
HTTP_AUTH_RATE_LIMIT_RATE=10
HTTP_AUTH_RATE_LIMIT_BURST=20
HTTP_AUTH_RATE_LIMIT_EXPIRES_SEC=60
HTTP_REGISTRATION_ENABLED=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=gotemplate
POSTGRES_PASSWORD=gotemplate_password
POSTGRES_DB=gotemplate_db
POSTGRES_SSL_MODE=disable
POSTGRES_POOL_MAX_CONNS=20
POSTGRES_POOL_MIN_CONNS=4

# Metrics
METRICS_NAMESPACE=gotemplate
METRICS_SUBSYSTEM=
METRICS_CONST_LABELS=app=gotemplate

# Jaeger Tracing
JAEGER_URL=http://localhost:4318/v1/traces
JAEGER_APP_NAME=gotemplate
JAEGER_INSECURE=true

# Idempotency
IDEMPOTENCY_TTL_DAYS=3
