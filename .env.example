# Application
APP_ENV=dev                                    # required: test|dev|prod
LOG_LEVEL=info                                 # optional: debug|info|warn|error
APP_SHUTDOWN_TIMEOUT_SEC=5                     # optional: graceful shutdown timeout in seconds

# HTTP
HTTP_HOST=0.0.0.0                              # required
HTTP_PORT=8080                                 # required
HTTP_SECRET_KEY=change-me-min-32-chars-secret! # required: JWT signing key
HTTP_CORS_ALLOWED_ORIGINS=http://localhost:3000 # required: comma-separated origins
HTTP_REQUEST_TIMEOUT_SEC=30                    # optional: per-request deadline in seconds
HTTP_AUTH_RATE_LIMIT_RATE=10                   # optional: req/s per IP on /auth endpoints
HTTP_AUTH_RATE_LIMIT_BURST=20                  # optional: burst size
HTTP_AUTH_RATE_LIMIT_EXPIRES_SEC=60            # optional: rate limit window in seconds
HTTP_REGISTRATION_ENABLED=true                 # optional: set false to disable public signup

# PostgreSQL
POSTGRES_HOST=localhost                        # required
POSTGRES_PORT=5432                             # required
POSTGRES_USER=gotemplate                       # required
POSTGRES_PASSWORD=gotemplate                   # required
POSTGRES_DB=gotemplate                         # required
POSTGRES_SSL_MODE=disable                      # optional: disable|require|prefer
POSTGRES_POOL_MAX_CONNS=20                     # optional
POSTGRES_POOL_MIN_CONNS=4                      # optional

# Metrics (Prometheus)
METRICS_NAMESPACE=                             # optional
METRICS_SUBSYSTEM=                             # optional
METRICS_CONST_LABELS=app=gotemplate            # optional: comma-separated k=v pairs

# Jaeger / OpenTelemetry tracing
JAEGER_URL=                                    # optional: empty = tracing disabled
JAEGER_APP_NAME=gotemplate                     # optional
JAEGER_INSECURE=false                          # optional

# Idempotency
IDEMPOTENCY_TTL_DAYS=1                         # optional: cache entry lifetime in days
IDEMPOTENCY_MAX_CACHE_ENTRIES=10000            # optional: LRU capacity
IDEMPOTENCY_CLEANUP_INTERVAL_MIN=60            # optional: cleanup goroutine interval in minutes
